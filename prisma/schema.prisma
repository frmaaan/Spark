// =============================================================
// 📚 PRISMA SCHEMA — Definisi Struktur Database
// =============================================================
// 
// KONSEP: Prisma Schema adalah "blueprint" database kamu.
// Di sini kita mendefinisikan:
//   1. Generator  → Bagaimana Prisma menghasilkan kode client
//   2. Datasource → Database apa yang dipakai (SQLite)
//   3. Model      → Tabel-tabel di database
//
// Prisma akan membaca file ini dan:
//   - Membuat tabel di database (migration)
//   - Menghasilkan TypeScript/JS client untuk query data
//
// ANALOGI: Seperti CREATE TABLE di SQL, tapi lebih readable
// =============================================================

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
  // output → Lokasi dimana Prisma Client di-generate
  // Kita taruh di app/generated agar mudah diakses
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// MODEL: User (Tabel Pengguna)
// =============================================================
// Menyimpan data karyawan: Nomor Finger, NIP/NIK, dan Nama
//
// KONSEP:
// - @id          → Primary key (identitas unik setiap record)
// - @default     → Nilai default saat record dibuat
// - autoincrement() → ID otomatis bertambah (1, 2, 3, ...)
// - @unique      → Tidak boleh ada duplikat
// - @map         → Nama kolom di database (bisa beda dari nama field)
// - @@map        → Nama tabel di database
// =============================================================
model User {
  id          Int       @id @default(autoincrement())
  nomorFinger String    @unique @map("nomor_finger")
  nip         String    @unique // NIP atau NIK karyawan
  nama        String // Nama lengkap karyawan
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at") // null = aktif, terisi = sudah dihapus (soft delete)
  accountId   Int?      @map("account_id") // ID dari Account pembuat data

  // RELASI: Satu user bisa punya banyak baris SPKL
  // Ini disebut "One-to-Many Relationship"
  spklRows SpklRow[]
  teamId   Int?
  team     Team?     @relation(fields: [teamId], references: [id])

  @@map("users") // Nama tabel di database = "users"
}

// =============================================================
// MODEL: Spkl (Tabel Surat Perintah Kerja Lembur)
// =============================================================
// Menyimpan header SPKL (tanggal dibuat)
// Satu SPKL bisa punya banyak baris detail (SpklRow)
// =============================================================
model Spkl {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  status    String   @default("DRAFT") // "DRAFT" | "FINAL"
  accountId Int?     @map("account_id") // ID dari Account pembuat SPKL

  account Account? @relation(fields: [accountId], references: [id])

  // RELASI: Satu SPKL punya banyak baris
  rows SpklRow[]

  @@map("spkl")
}

// =============================================================
// MODEL: SpklRow (Tabel Detail Baris SPKL)
// =============================================================
// Setiap baris berisi: Siapa (user), Kapan (tanggal), Apa (keterangan)
//
// KONSEP RELASI:
// - userId → Foreign Key ke tabel User
// - spklId → Foreign Key ke tabel Spkl
// - @relation → Mendefinisikan hubungan antar tabel
//   - fields: [userId]    → Kolom di tabel ini yang jadi FK
//   - references: [id]    → Kolom di tabel target yang dirujuk
// =============================================================
model SpklRow {
  id Int @id @default(autoincrement())

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])
  // ^ Relasi ke User: "baris ini milik user dengan id = userId"

  spklId Int  @map("spkl_id")
  spkl   Spkl @relation(fields: [spklId], references: [id], onDelete: Cascade)
  // ^ Relasi ke Spkl: "baris ini bagian dari SPKL dengan id = spklId"
  // onDelete: Cascade → Jika SPKL dihapus, semua barisnya ikut terhapus

  tanggal    String // Format: YYYY-MM-DD
  keterangan String // Deskripsi pekerjaan lembur

  createdAt DateTime @default(now()) @map("created_at")

  @@map("spkl_rows")
}

// =============================================================
// MODEL: Account (Tabel Akun Login)
// =============================================================
// Menyimpan data pengguna yang memiliki akses login ke sistem
// =============================================================
model Account {
  id        Int      @id @default(autoincrement())
  nama      String // Nama pengguna untuk ditampilkan di sidebar
  username  String   @unique
  password  String // Akan disimpan dalam bentuk hash (bcrypt)
  role      String   @default("USER") // "ADMIN" atau "USER"
  createdAt DateTime @default(now()) @map("created_at")

  teamId Int?  @map("team_id")
  team   Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  spkls Spkl[]
  todos Todo[]

  @@map("accounts")
}

// =============================================================
// MODEL: Setting (Pengaturan Sistem Dinamis)
// =============================================================
model Setting {
  key   String @id
  value String

  @@map("settings")
}

// =============================================================
// MODEL: Team (Tabel Tim Kolaborasi)
// =============================================================
model Team {
  id   Int    @id @default(autoincrement())
  nama String @unique // contoh: "Tim IT", "Tim Gudang"

  accounts      Account[] // Berubah jadi jamak (accounts)
  todos         Todo[]
  users         User[]
  todoTemplates TodoTemplate[]
  monitoringCategoryTeams MonitoringCategoryTeam[]

  @@map("teams")
}

// =============================================================
// MODEL: Todo (Tabel To-Do List)
// =============================================================
model Todo {
  id          Int     @id @default(autoincrement())
  task        String
  description String? @db.Text
  status      String  @default("TODO") // "TODO" | "IN_PROGRESS" | "DONE"
  tipe        String  @default("PERSONAL") // "PERSONAL" | "TEAM"

  authorId Int     @map("author_id")
  author   Account @relation(fields: [authorId], references: [id], onDelete: Cascade)

  teamId Int?  @map("team_id")
  team   Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("todos")
}

// =============================================================
// MODEL: TodoTemplate (Template Checklist dari Admin)
// =============================================================
model TodoTemplate {
  id        Int      @id @default(autoincrement())
  title     String // Judul template: "Checklist Harian Gudang"
  items     String   @db.Text // JSON array: ["Cek stok", "Update inventaris", ...]
  createdAt DateTime @default(now()) @map("created_at")

  teamId Int?  @map("team_id")
  team   Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@map("todo_templates")
}

// =============================================================
// MODEL: TodoHistory (Snapshot dari sebuah periode, disimpan saat midnight)
// =============================================================
model TodoHistory {
  id        Int      @id @default(autoincrement())
  title     String // Judul snapshot, mis. "Snapshot 2026-04-29"
  items     String   @db.Text // JSON array of todo objects
  authorId  Int?     @map("author_id")
  teamId    Int?     @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("todo_histories")
}

// =============================================================
// MODEL: MonitoringCategory (Kategori Papan Monitoring)
// =============================================================
model MonitoringCategory {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  
  items     MonitoringItem[]
  categoryTeams MonitoringCategoryTeam[]
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("monitoring_categories")
}

// =============================================================
// MODEL: MonitoringItem (Produk/Barang yang dimonitor)
// =============================================================
model MonitoringItem {
  id           Int      @id @default(autoincrement())
  categoryId   Int      @map("category_id")
  kode         String   @unique
  nama         String
  stokAwal     Int      @default(0) @map("stok_awal")
  
  category     MonitoringCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions MonitoringTransaction[]

  createdAt    DateTime @default(now()) @map("created_at")

  @@map("monitoring_items")
}

// Join table: many-to-many between MonitoringCategory and Team
model MonitoringCategoryTeam {
  id          Int @id @default(autoincrement())
  categoryId  Int @map("category_id")
  teamId      Int @map("team_id")

  category    MonitoringCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([categoryId, teamId])
  @@map("monitoring_category_teams")
}

// =============================================================
// MODEL: MonitoringLocation (Lokasi/Gudang Penyimpanan)
// =============================================================
model MonitoringLocation {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  
  transactions MonitoringTransaction[] @relation("LocationTransactions")
  incomingTransfers MonitoringTransaction[] @relation("IncomingTransfers")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("monitoring_locations")
}

// =============================================================
// MODEL: MonitoringTransaction (Riwayat Mutasi In/Out/Transfer)
// =============================================================
model MonitoringTransaction {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  
  tipe      String   // Wajib bernilai "IN", "OUT", atau "TRANSFER"
  qty       Int
  tanggal   DateTime
  catatan   String?  @db.Text
  
  locationId Int?    @map("location_id")
  location   MonitoringLocation? @relation("LocationTransactions", fields: [locationId], references: [id], onDelete: Cascade)

  toLocationId Int?  @map("to_location_id") // Tujuan untuk TRANSFER
  toLocation   MonitoringLocation? @relation("IncomingTransfers", fields: [toLocationId], references: [id], onDelete: Cascade)

  // Opsional: Lacak siapa yang menginput
  // authorId Int?     @map("author_id")

  item      MonitoringItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("monitoring_transactions")
}