generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  nomorFinger String    @unique @map("nomor_finger")
  nip         String    @unique
  nama        String
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  accountId   Int?      @map("account_id")
  teamId      Int?
  spklRows    SpklRow[]
  team        Team?     @relation(fields: [teamId], references: [id])

  @@map("users")
}

model Spkl {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now()) @map("created_at")
  status    String    @default("DRAFT")
  accountId Int?      @map("account_id")
  teamId    Int?      @map("team_id")
  account   Account?  @relation(fields: [accountId], references: [id])
  team      Team?     @relation(fields: [teamId], references: [id])
  rows      SpklRow[]

  @@map("spkl")
}

model SpklRow {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  spklId     Int      @map("spkl_id")
  tanggal    String
  keterangan String
  createdAt  DateTime @default(now()) @map("created_at")
  spkl       Spkl     @relation(fields: [spklId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@map("spkl_rows")
}

model Account {
  id                 Int                 @id @default(autoincrement())
  nama               String
  username           String              @unique
  password           String
  role               String              @default("USER")
  createdAt          DateTime            @default(now()) @map("created_at")
  teamId             Int?                @map("team_id")
  team               Team?               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  elearningMaterials ElearningMaterial[]
  elearningQuestions ElearningQuestion[]
  schedule_changes   schedule_changes[]
  schedules          Schedule[]
  spkls              Spkl[]
  todos              Todo[]

  @@map("accounts")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model Team {
  id                      Int                      @id @default(autoincrement())
  nama                    String                   @unique
  accounts                Account[]
  elearningMaterials      ElearningMaterial[]
  elearningQuestions      ElearningQuestion[]
  monitoringCategoryTeams MonitoringCategoryTeam[]
  schedules               Schedule[]
  spkls                   Spkl[]
  todoTemplates           TodoTemplate[]
  todos                   Todo[]
  users                   User[]

  @@map("teams")
}

model Todo {
  id          Int      @id @default(autoincrement())
  task        String
  tipe        String   @default("PERSONAL")
  authorId    Int      @map("author_id")
  teamId      Int?     @map("team_id")
  createdAt   DateTime @default(now()) @map("created_at")
  description String?
  status      String   @default("TODO")
  author      Account  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("todos")
}

model TodoTemplate {
  id        Int      @id @default(autoincrement())
  title     String
  items     String
  createdAt DateTime @default(now()) @map("created_at")
  teamId    Int?     @map("team_id")
  team      Team?    @relation(fields: [teamId], references: [id])

  @@map("todo_templates")
}

model ElearningMaterial {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  items        Json
  accessStatus String    @default("TEAM")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  teamId       Int?      @map("team_id")
  createdBy    Int?      @map("created_by")
  publicSlug   String?   @unique @map("public_slug")
  creator      Account?  @relation(fields: [createdBy], references: [id])
  team         Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("elearning_materials")
}

model ElearningQuestion {
  id           Int       @id @default(autoincrement())
  question     String
  answer       String
  accessStatus String    @default("TEAM")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  teamId       Int?      @map("team_id")
  createdBy    Int?      @map("created_by")
  creator      Account?  @relation(fields: [createdBy], references: [id])
  team         Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("elearning_questions")
}

model TodoHistory {
  id        Int      @id @default(autoincrement())
  title     String
  items     String
  authorId  Int?     @map("author_id")
  teamId    Int?     @map("team_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("todo_histories")
}

model MonitoringCategory {
  id            Int                      @id @default(autoincrement())
  nama          String                   @unique
  createdAt     DateTime                 @default(now()) @map("created_at")
  categoryTeams MonitoringCategoryTeam[]
  items         MonitoringItem[]

  @@map("monitoring_categories")
}

model MonitoringItem {
  id           Int                     @id @default(autoincrement())
  categoryId   Int                     @map("category_id")
  kode         String                  @unique
  nama         String
  stokAwal     Int                     @default(0) @map("stok_awal")
  createdAt    DateTime                @default(now()) @map("created_at")
  category     MonitoringCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions MonitoringTransaction[]

  @@map("monitoring_items")
}

model MonitoringCategoryTeam {
  id         Int                @id @default(autoincrement())
  categoryId Int                @map("category_id")
  teamId     Int                @map("team_id")
  category   MonitoringCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  team       Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([categoryId, teamId])
  @@map("monitoring_category_teams")
}

model MonitoringLocation {
  id                Int                     @id @default(autoincrement())
  nama              String                  @unique
  createdAt         DateTime                @default(now()) @map("created_at")
  transactions      MonitoringTransaction[] @relation("LocationTransactions")
  incomingTransfers MonitoringTransaction[] @relation("IncomingTransfers")

  @@map("monitoring_locations")
}

model MonitoringTransaction {
  id           Int                 @id @default(autoincrement())
  itemId       Int                 @map("item_id")
  tipe         String
  qty          Int
  tanggal      DateTime
  catatan      String?
  createdAt    DateTime            @default(now()) @map("created_at")
  locationId   Int?                @map("location_id")
  toLocationId Int?                @map("to_location_id")
  item         MonitoringItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location     MonitoringLocation? @relation("LocationTransactions", fields: [locationId], references: [id], onDelete: Cascade)
  toLocation   MonitoringLocation? @relation("IncomingTransfers", fields: [toLocationId], references: [id], onDelete: Cascade)

  @@map("monitoring_transactions")
}

model Schedule {
  id               Int                @id @default(autoincrement())
  teamId           Int?               @map("team_id")
  createdBy        Int?               @map("created_by")
  monthStartDate   DateTime           @map("month_start_date")
  publicSlug       String?            @unique @map("public_slug")
  createdAt        DateTime           @default(now()) @map("created_at")
  deletedAt        DateTime?          @map("deleted_at")
  schedule_changes schedule_changes[]
  rows             ScheduleRow[]
  creator          Account?           @relation(fields: [createdBy], references: [id])
  team             Team?              @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model ScheduleRow {
  id               Int                @id @default(autoincrement())
  scheduleId       Int                @map("schedule_id")
  nomorFinger      String             @map("nomor_finger")
  namaKaryawan     String             @map("nama_karyawan")
  shifts           Json
  version          Int                @default(1)
  schedule_changes schedule_changes[]
  schedule         Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("schedule_rows")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model schedule_changes {
  id            Int         @id @default(autoincrement())
  schedule_id   Int
  row_id        Int
  day           Int
  old_value     String?
  new_value     String
  changed_by    Int?
  reason        String?
  created_at    DateTime    @default(now())
  accounts      Account?    @relation(fields: [changed_by], references: [id])
  schedule_rows ScheduleRow @relation(fields: [row_id], references: [id], onDelete: Cascade)
  schedules     Schedule    @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
}
